{
  "name": "salesforcedx-vscode-manager",
  "displayName": "%salesforcedx-vscode-manager.displayName%",
  "description": "%salesforcedx-vscode-manager.description%",
  "version": "0.1.0",
  "publisher": "salesforce",
  "license": "BSD-3-Clause",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionDependencies": [
    "salesforce.salesforcedx-vscode-core"
  ],
  "dependencies": {
    "@salesforce/vscode-service-provider": "^1.3.0-rc.6.5"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      { "command": "sfdxManager.applyGroupQuickPick", "title": "%salesforcedx-vscode-manager.command.applyGroupQuickPick.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(play)" },
      { "command": "sfdxManager.applyGroup", "title": "%salesforcedx-vscode-manager.command.applyGroup.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(play)" },
      { "command": "sfdxManager.enableAllSalesforce", "title": "%salesforcedx-vscode-manager.command.enableAllSalesforce.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(check-all)" },
      { "command": "sfdxManager.disableAllSalesforce", "title": "%salesforcedx-vscode-manager.command.disableAllSalesforce.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(circle-slash)" },
      { "command": "sfdxManager.createCustomGroup", "title": "%salesforcedx-vscode-manager.command.createCustomGroup.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(add)" },
      { "command": "sfdxManager.editGroup", "title": "%salesforcedx-vscode-manager.command.editGroup.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(edit)" },
      { "command": "sfdxManager.deleteGroup", "title": "%salesforcedx-vscode-manager.command.deleteGroup.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(trash)" },
      { "command": "sfdxManager.openGroupsConfig", "title": "%salesforcedx-vscode-manager.command.openGroupsConfig.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(settings-gear)" },
      { "command": "sfdxManager.showDependencies", "title": "%salesforcedx-vscode-manager.command.showDependencies.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(checklist)" },
      { "command": "sfdxManager.runDependencyCheck", "title": "%salesforcedx-vscode-manager.command.runDependencyCheck.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(refresh)" },
      { "command": "sfdxManager.copyDependencyReport", "title": "%salesforcedx-vscode-manager.command.copyDependencyReport.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(clippy)" },
      { "command": "sfdxManager.openRemediationUrl", "title": "%salesforcedx-vscode-manager.command.openRemediationUrl.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(link-external)" },
      { "command": "sfdxManager.refreshFromVsixDirectory", "title": "%salesforcedx-vscode-manager.command.refreshFromVsixDirectory.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(cloud-download)" },
      { "command": "sfdxManager.openVsixDirectory", "title": "%salesforcedx-vscode-manager.command.openVsixDirectory.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(folder-opened)" },
      { "command": "sfdxManager.clearVsixOverrides", "title": "%salesforcedx-vscode-manager.command.clearVsixOverrides.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(clear-all)" },
      { "command": "sfdxManager.vsixMenu", "title": "%salesforcedx-vscode-manager.command.vsixMenu.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(package)" },
      { "command": "sfdxManager.showLog", "title": "%salesforcedx-vscode-manager.command.showLog.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(output)" },
      { "command": "sfdxManager.updateExtension", "title": "%salesforcedx-vscode-manager.command.updateExtension.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(arrow-circle-up)" },
      { "command": "sfdxManager.updateAllSalesforce", "title": "%salesforcedx-vscode-manager.command.updateAllSalesforce.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(sync)" },
      { "command": "sfdxManager.checkForUpdates", "title": "%salesforcedx-vscode-manager.command.checkForUpdates.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(search-refresh)" },
      { "command": "sfdxManager.exportGroups", "title": "%salesforcedx-vscode-manager.command.exportGroups.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(cloud-upload)" },
      { "command": "sfdxManager.importGroups", "title": "%salesforcedx-vscode-manager.command.importGroups.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(cloud-download)" },
      { "command": "sfdxManager.moveGroupScope", "title": "%salesforcedx-vscode-manager.command.moveGroupScope.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(arrow-both)" },
      { "command": "sfdxManager.browseSalesforceExtensions", "title": "%salesforcedx-vscode-manager.command.browseSalesforceExtensions.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(cloud)" },
      { "command": "sfdxManager.refreshSalesforceCatalog", "title": "%salesforcedx-vscode-manager.command.refreshSalesforceCatalog.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(cloud-download)" },
      { "command": "sfdxManager.installExtension", "title": "%salesforcedx-vscode-manager.command.installExtension.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(cloud-download)" },
      { "command": "sfdxManager.uninstallExtension", "title": "%salesforcedx-vscode-manager.command.uninstallExtension.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(trash)" },
      { "command": "sfdxManager.openInMarketplace", "title": "%salesforcedx-vscode-manager.command.openInMarketplace.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(link-external)" },
      { "command": "sfdxManager.removeVsixOverride", "title": "%salesforcedx-vscode-manager.command.removeVsixOverride.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(trash)" },
      { "command": "sfdxManager.revealVsixFile", "title": "%salesforcedx-vscode-manager.command.revealVsixFile.title%", "category": "%salesforcedx-vscode-manager.commandCategory%", "icon": "$(folder-opened)" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "sfdxManager.applyGroup", "when": "false" },
        { "command": "sfdxManager.openRemediationUrl", "when": "false" },
        { "command": "sfdxManager.updateExtension", "when": "false" },
        { "command": "sfdxManager.installExtension", "when": "false" },
        { "command": "sfdxManager.uninstallExtension", "when": "false" },
        { "command": "sfdxManager.openInMarketplace", "when": "false" },
        { "command": "sfdxManager.removeVsixOverride", "when": "false" },
        { "command": "sfdxManager.revealVsixFile", "when": "false" }
      ],
      "view/title": [
        { "command": "sfdxManager.createCustomGroup", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy", "group": "navigation" },
        { "command": "sfdxManager.applyGroupQuickPick", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy", "group": "navigation" },
        { "command": "sfdxManager.updateAllSalesforce", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy", "group": "navigation" },
        { "command": "sfdxManager.checkForUpdates", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy", "group": "navigation" },
        { "command": "sfdxManager.browseSalesforceExtensions", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy", "group": "navigation" },
        { "command": "sfdxManager.refreshFromVsixDirectory", "when": "view == sfdxManager.vsix && !sfdxManager.anyBusy", "group": "navigation@1" },
        { "command": "sfdxManager.openVsixDirectory", "when": "view == sfdxManager.vsix", "group": "navigation@2" },
        { "command": "sfdxManager.clearVsixOverrides", "when": "view == sfdxManager.vsix && !sfdxManager.anyBusy", "group": "navigation@3" },
        { "command": "sfdxManager.runDependencyCheck", "when": "view == sfdxManager.dependencies", "group": "navigation" },
        { "command": "sfdxManager.copyDependencyReport", "when": "view == sfdxManager.dependencies", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "sfdxManager.applyGroup", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^group:/ && viewItem != group:catalog", "group": "inline" },
        { "command": "sfdxManager.editGroup", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && (viewItem == group:user || viewItem == group:builtIn)", "group": "1_modify@1" },
        { "command": "sfdxManager.deleteGroup", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && (viewItem == group:user || viewItem == group:builtIn)", "group": "1_modify@2" },
        { "command": "sfdxManager.moveGroupScope", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem == group:user", "group": "1_modify@3" },
        { "command": "sfdxManager.refreshSalesforceCatalog", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem == group:catalog", "group": "inline" },
        { "command": "sfdxManager.openInMarketplace", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem == group:pack", "group": "inline@2" },
        { "command": "sfdxManager.installExtension", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/ && viewItem =~ /notInstalled/ && !(viewItem =~ /:locked/) && !(viewItem =~ /:vsixLocked/)", "group": "inline@1" },
        { "command": "sfdxManager.uninstallExtension", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/ && viewItem =~ /(^|:)installed/ && !(viewItem =~ /:locked/) && !(viewItem =~ /:vsixLocked/)", "group": "inline@3" },
        { "command": "sfdxManager.updateExtension", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/ && viewItem =~ /updateAvailable/ && !(viewItem =~ /:vsixLocked/)", "group": "inline@2" },
        { "command": "sfdxManager.openInMarketplace", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/", "group": "inline@4" },
        { "command": "sfdxManager.openInMarketplace", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension:child:/", "group": "inline@1" },
        { "command": "sfdxManager.installExtension", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/ && !(viewItem =~ /^extension:child:/) && viewItem =~ /notInstalled/ && !(viewItem =~ /:locked/) && !(viewItem =~ /:vsixLocked/)", "group": "1_ext@1" },
        { "command": "sfdxManager.updateExtension", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/ && !(viewItem =~ /^extension:child:/) && viewItem =~ /updateAvailable/ && !(viewItem =~ /:vsixLocked/)", "group": "1_ext@2" },
        { "command": "sfdxManager.uninstallExtension", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/ && !(viewItem =~ /^extension:child:/) && viewItem =~ /(^|:)installed/ && !(viewItem =~ /:locked/) && !(viewItem =~ /:vsixLocked/)", "group": "1_ext@3" },
        { "command": "sfdxManager.openInMarketplace", "when": "view == sfdxManager.groups && !sfdxManager.anyBusy && viewItem =~ /^extension/", "group": "2_ext_nav@1" },
        { "command": "sfdxManager.revealVsixFile", "when": "view == sfdxManager.vsix && viewItem == vsix:override", "group": "inline@1" },
        { "command": "sfdxManager.removeVsixOverride", "when": "view == sfdxManager.vsix && !sfdxManager.anyBusy && viewItem == vsix:override", "group": "inline@2" },
        { "command": "sfdxManager.runDependencyCheck", "when": "view == sfdxManager.dependencies && viewItem =~ /^check/", "group": "inline" },
        { "command": "sfdxManager.openRemediationUrl", "when": "view == sfdxManager.dependencies && viewItem == check:withRemediationUrl", "group": "inline" }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sfdxManager",
          "title": "%salesforcedx-vscode-manager.viewContainer.title%",
          "icon": "resources/icons/sfdx-manager.svg"
        }
      ]
    },
    "views": {
      "sfdxManager": [
        {
          "id": "sfdxManager.groups",
          "name": "%salesforcedx-vscode-manager.view.groups.name%"
        },
        {
          "id": "sfdxManager.vsix",
          "name": "%salesforcedx-vscode-manager.view.vsix.name%",
          "when": "sfdxManager.hasVsixOverrides"
        },
        {
          "id": "sfdxManager.dependencies",
          "name": "%salesforcedx-vscode-manager.view.dependencies.name%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sfdxManager.groups",
        "contents": "%salesforcedx-vscode-manager.viewsWelcome.groups%"
      },
      {
        "view": "sfdxManager.vsix",
        "contents": "%salesforcedx-vscode-manager.viewsWelcome.vsix%"
      },
      {
        "view": "sfdxManager.dependencies",
        "contents": "%salesforcedx-vscode-manager.viewsWelcome.dependencies%"
      }
    ],
    "configuration": {
      "title": "%salesforcedx-vscode-manager.configuration.title%",
      "properties": {
        "salesforcedx-vscode-manager.groups": {
          "type": "object",
          "default": {},
          "description": "%salesforcedx-vscode-manager.configuration.groups.description%"
        },
        "salesforcedx-vscode-manager.applyScope": {
          "type": "string",
          "enum": ["disableOthers", "enableOnly", "ask"],
          "default": "disableOthers",
          "description": "%salesforcedx-vscode-manager.configuration.applyScope.description%"
        },
        "salesforcedx-vscode-manager.backend": {
          "type": "string",
          "enum": ["codeCli", "profiles"],
          "enumDescriptions": [
            "%salesforcedx-vscode-manager.configuration.backend.codeCli%",
            "%salesforcedx-vscode-manager.configuration.backend.profiles%"
          ],
          "default": "codeCli",
          "description": "%salesforcedx-vscode-manager.configuration.backend.description%"
        },
        "salesforcedx-vscode-manager.autoRunDependencyChecks": {
          "type": "boolean",
          "default": false,
          "description": "%salesforcedx-vscode-manager.configuration.autoRunDependencyChecks.description%"
        },
        "salesforcedx-vscode-manager.thirdPartyExtensionIds": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "redhat.vscode-xml",
            "dbaeumer.vscode-eslint",
            "esbenp.prettier-vscode",
            "salesforce.lightning-design-system-vscode"
          ],
          "description": "%salesforcedx-vscode-manager.configuration.thirdPartyExtensionIds.description%"
        },
        "salesforcedx-vscode-manager.vsixDirectory": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "%salesforcedx-vscode-manager.configuration.vsixDirectory.description%"
        },
        "salesforcedx-vscode-manager.vsixAutoInstall": {
          "type": "boolean",
          "default": true,
          "description": "%salesforcedx-vscode-manager.configuration.vsixAutoInstall.description%"
        },
        "salesforcedx-vscode-manager.statusBar.showGroup": {
          "type": "boolean",
          "default": true,
          "description": "%salesforcedx-vscode-manager.configuration.statusBar.showGroup.description%"
        },
        "salesforcedx-vscode-manager.reloadAfterApply": {
          "type": "string",
          "enum": ["auto", "prompt", "never"],
          "enumDescriptions": [
            "%salesforcedx-vscode-manager.configuration.reloadAfterApply.auto%",
            "%salesforcedx-vscode-manager.configuration.reloadAfterApply.prompt%",
            "%salesforcedx-vscode-manager.configuration.reloadAfterApply.never%"
          ],
          "default": "prompt",
          "description": "%salesforcedx-vscode-manager.configuration.reloadAfterApply.description%"
        },
        "salesforcedx-vscode-manager.statusBar.showVsix": {
          "type": "boolean",
          "default": true,
          "description": "%salesforcedx-vscode-manager.configuration.statusBar.showVsix.description%"
        },
        "salesforcedx-vscode-manager.updateCheck": {
          "type": "string",
          "enum": ["onStartup", "manual", "never"],
          "enumDescriptions": [
            "%salesforcedx-vscode-manager.configuration.updateCheck.onStartup%",
            "%salesforcedx-vscode-manager.configuration.updateCheck.manual%",
            "%salesforcedx-vscode-manager.configuration.updateCheck.never%"
          ],
          "default": "manual",
          "description": "%salesforcedx-vscode-manager.configuration.updateCheck.description%"
        },
        "salesforcedx-vscode-manager.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%salesforcedx-vscode-manager.configuration.telemetry.enabled.description%"
        }
      }
    },
    "keybindings": [
      {
        "command": "sfdxManager.applyGroupQuickPick",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g"
      }
    ],
    "walkthroughs": [
      {
        "id": "sfdxManager.getStarted",
        "title": "%salesforcedx-vscode-manager.walkthrough.title%",
        "description": "%salesforcedx-vscode-manager.walkthrough.description%",
        "steps": [
          {
            "id": "sfdxManager.walkthrough.applyGroup",
            "title": "%salesforcedx-vscode-manager.walkthrough.applyGroup.title%",
            "description": "%salesforcedx-vscode-manager.walkthrough.applyGroup.description%",
            "media": { "markdown": "resources/walkthrough/apply-group.md" }
          },
          {
            "id": "sfdxManager.walkthrough.dependencies",
            "title": "%salesforcedx-vscode-manager.walkthrough.dependencies.title%",
            "description": "%salesforcedx-vscode-manager.walkthrough.dependencies.description%",
            "media": { "markdown": "resources/walkthrough/dependencies.md" }
          },
          {
            "id": "sfdxManager.walkthrough.vsix",
            "title": "%salesforcedx-vscode-manager.walkthrough.vsix.title%",
            "description": "%salesforcedx-vscode-manager.walkthrough.vsix.description%",
            "media": { "markdown": "resources/walkthrough/vsix.md" }
          },
          {
            "id": "sfdxManager.walkthrough.statusBar",
            "title": "%salesforcedx-vscode-manager.walkthrough.statusBar.title%",
            "description": "%salesforcedx-vscode-manager.walkthrough.statusBar.description%",
            "media": { "markdown": "resources/walkthrough/status-bar.md" }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit && node ./esbuild.js",
    "watch": "tsc --noEmit --watch",
    "clean": "rimraf out dist coverage",
    "bundle:extension": "node ./esbuild.js --production",
    "bundle:vsix": "npm run bundle:extension && npx -y @vscode/vsce package --allow-missing-repository --baseContentUrl https://example.invalid/",
    "vscode:prepublish": "npm run bundle:extension",
    "l10n": "npx -y @vscode/l10n-dev export --outDir ./l10n ./src",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^29.5.1",
    "@types/node": "^22",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
