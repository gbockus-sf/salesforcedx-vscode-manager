{
  "name": "salesforcedx-vscode-manager",
  "displayName": "Salesforce Extensions Manager",
  "description": "Manage which Salesforce VSCode extensions are enabled, verify external dependencies, and override with local VSIX builds.",
  "version": "0.1.0",
  "publisher": "salesforce",
  "license": "BSD-3-Clause",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {},
  "scripts": {
    "compile": "tsc --noEmit && node ./esbuild.js",
    "watch": "tsc --noEmit --watch",
    "clean": "rimraf out dist coverage",
    "bundle:extension": "node ./esbuild.js --production",
    "bundle:vsix": "npm run compile && vsce package",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^29.5.1",
    "@types/node": "^22",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
