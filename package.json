{
  "name": "salesforcedx-vscode-manager",
  "displayName": "Salesforce Extensions Manager",
  "description": "Manage which Salesforce VSCode extensions are enabled, verify external dependencies, and override with local VSIX builds.",
  "version": "0.1.0",
  "publisher": "salesforce",
  "license": "BSD-3-Clause",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      { "command": "sfdxManager.applyGroupQuickPick", "title": "Apply Group...", "category": "SFDX Manager", "icon": "$(play)" },
      { "command": "sfdxManager.applyGroup", "title": "Apply Group", "category": "SFDX Manager", "icon": "$(play)" },
      { "command": "sfdxManager.enableAllSalesforce", "title": "Enable All Managed Extensions", "category": "SFDX Manager", "icon": "$(check-all)" },
      { "command": "sfdxManager.disableAllSalesforce", "title": "Disable All Managed Extensions", "category": "SFDX Manager", "icon": "$(circle-slash)" },
      { "command": "sfdxManager.createCustomGroup", "title": "Create Custom Group", "category": "SFDX Manager", "icon": "$(add)" },
      { "command": "sfdxManager.editGroup", "title": "Edit Group", "category": "SFDX Manager", "icon": "$(edit)" },
      { "command": "sfdxManager.deleteGroup", "title": "Delete Group", "category": "SFDX Manager", "icon": "$(trash)" },
      { "command": "sfdxManager.openGroupsConfig", "title": "Open Groups Setting", "category": "SFDX Manager", "icon": "$(settings-gear)" },
      { "command": "sfdxManager.showDependencies", "title": "Show Dependencies", "category": "SFDX Manager", "icon": "$(checklist)" },
      { "command": "sfdxManager.runDependencyCheck", "title": "Run Dependency Check", "category": "SFDX Manager", "icon": "$(refresh)" },
      { "command": "sfdxManager.copyDependencyReport", "title": "Copy Dependency Report", "category": "SFDX Manager", "icon": "$(clippy)" },
      { "command": "sfdxManager.openRemediationUrl", "title": "Open Remediation Link", "category": "SFDX Manager", "icon": "$(link-external)" },
      { "command": "sfdxManager.refreshFromVsixDirectory", "title": "Refresh from VSIX Directory", "category": "SFDX Manager", "icon": "$(cloud-download)" },
      { "command": "sfdxManager.openVsixDirectory", "title": "Open VSIX Directory", "category": "SFDX Manager", "icon": "$(folder-opened)" },
      { "command": "sfdxManager.clearVsixOverrides", "title": "Clear VSIX Overrides", "category": "SFDX Manager", "icon": "$(clear-all)" },
      { "command": "sfdxManager.vsixMenu", "title": "VSIX Management...", "category": "SFDX Manager", "icon": "$(package)" },
      { "command": "sfdxManager.showLog", "title": "Show Log", "category": "SFDX Manager", "icon": "$(output)" },
      { "command": "sfdxManager.updateExtension", "title": "Update Extension", "category": "SFDX Manager", "icon": "$(arrow-circle-up)" },
      { "command": "sfdxManager.updateAllSalesforce", "title": "Update All Salesforce Extensions", "category": "SFDX Manager", "icon": "$(sync)" },
      { "command": "sfdxManager.checkForUpdates", "title": "Check for Extension Updates", "category": "SFDX Manager", "icon": "$(search-refresh)" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "sfdxManager.applyGroup", "when": "false" },
        { "command": "sfdxManager.openRemediationUrl", "when": "false" },
        { "command": "sfdxManager.updateExtension", "when": "false" }
      ],
      "view/title": [
        { "command": "sfdxManager.createCustomGroup", "when": "view == sfdxManager.groups", "group": "navigation" },
        { "command": "sfdxManager.applyGroupQuickPick", "when": "view == sfdxManager.groups", "group": "navigation" },
        { "command": "sfdxManager.updateAllSalesforce", "when": "view == sfdxManager.groups", "group": "navigation" },
        { "command": "sfdxManager.checkForUpdates", "when": "view == sfdxManager.groups", "group": "navigation" },
        { "command": "sfdxManager.runDependencyCheck", "when": "view == sfdxManager.dependencies", "group": "navigation" },
        { "command": "sfdxManager.copyDependencyReport", "when": "view == sfdxManager.dependencies", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "sfdxManager.applyGroup", "when": "view == sfdxManager.groups && viewItem =~ /^group:/", "group": "inline" },
        { "command": "sfdxManager.editGroup", "when": "view == sfdxManager.groups && viewItem =~ /^group:/", "group": "1_modify@1" },
        { "command": "sfdxManager.deleteGroup", "when": "view == sfdxManager.groups && viewItem =~ /^group:/", "group": "1_modify@2" },
        { "command": "sfdxManager.updateExtension", "when": "view == sfdxManager.groups && viewItem =~ /^extension/ && viewItem =~ /updateAvailable/", "group": "inline" },
        { "command": "sfdxManager.runDependencyCheck", "when": "view == sfdxManager.dependencies && viewItem =~ /^check/", "group": "inline" },
        { "command": "sfdxManager.openRemediationUrl", "when": "view == sfdxManager.dependencies && viewItem == check:withRemediationUrl", "group": "inline" }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sfdxManager",
          "title": "Salesforce Extensions Manager",
          "icon": "resources/icons/sfdx-manager.svg"
        }
      ]
    },
    "views": {
      "sfdxManager": [
        {
          "id": "sfdxManager.groups",
          "name": "Groups"
        },
        {
          "id": "sfdxManager.dependencies",
          "name": "Dependencies"
        }
      ]
    },
    "configuration": {
      "title": "Salesforce Extensions Manager",
      "properties": {
        "salesforcedx-vscode-manager.groups": {
          "type": "object",
          "default": {},
          "description": "User-defined extension groups (merged with built-ins by id)."
        },
        "salesforcedx-vscode-manager.applyScope": {
          "type": "string",
          "enum": ["disableOthers", "enableOnly", "ask"],
          "default": "disableOthers",
          "description": "What to do with managed extensions not in the applied group."
        },
        "salesforcedx-vscode-manager.backend": {
          "type": "string",
          "enum": ["codeCli", "profiles"],
          "enumDescriptions": [
            "Use the `code` CLI to install/uninstall extensions. Applying a group with scope=disableOthers uninstalls non-members.",
            "Each group maps to a VSCode Profile; applying a group switches profiles (coarse-grained but cleanly isolated). Reserved for a future release."
          ],
          "default": "codeCli",
          "description": "How apply-group changes workspace extension state."
        },
        "salesforcedx-vscode-manager.useInternalCommands": {
          "type": "boolean",
          "default": true,
          "description": "Deprecated fallback flag. VSCode does not expose a stable API to toggle extension enablement; this setting has no effect under the codeCli backend."
        },
        "salesforcedx-vscode-manager.autoRunDependencyChecks": {
          "type": "boolean",
          "default": false,
          "description": "Run dependency checks automatically on startup."
        },
        "salesforcedx-vscode-manager.thirdPartyExtensionIds": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "redhat.vscode-xml",
            "dbaeumer.vscode-eslint",
            "esbenp.prettier-vscode",
            "salesforce.lightning-design-system-vscode"
          ],
          "description": "Non-Salesforce extensions the manager may enable/disable as part of a group."
        },
        "salesforcedx-vscode-manager.vsixDirectory": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Absolute path to a directory of local .vsix files. When a managed extension has a matching vsix, it is installed from there instead of the marketplace."
        },
        "salesforcedx-vscode-manager.vsixAutoReinstallOnChange": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reinstall a managed extension when a new matching vsix appears in the vsix directory."
        },
        "salesforcedx-vscode-manager.statusBar.showGroup": {
          "type": "boolean",
          "default": true,
          "description": "Show the active group in the status bar."
        },
        "salesforcedx-vscode-manager.statusBar.showVsix": {
          "type": "boolean",
          "default": true,
          "description": "Show the VSIX override indicator in the status bar when a vsix directory is set."
        },
        "salesforcedx-vscode-manager.updateCheck": {
          "type": "string",
          "enum": ["onStartup", "manual", "never"],
          "enumDescriptions": [
            "Probe the Marketplace for newer versions of managed extensions shortly after activation.",
            "Only check when the user explicitly invokes the 'Check for Extension Updates' command or expands the tree after a refresh.",
            "Never contact the Marketplace; only show the locally installed version."
          ],
          "default": "manual",
          "description": "When the manager should probe the VSCode Marketplace for newer versions of managed extensions. Results are cached in memory for ~1 hour."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "sfdxManager.getStarted",
        "title": "Get Started with the Salesforce Extensions Manager",
        "description": "Switch between extension groups, verify dependencies, and swap in local VSIX builds.",
        "steps": [
          {
            "id": "sfdxManager.walkthrough.applyGroup",
            "title": "Apply an extension group",
            "description": "Quickly enable the set of Salesforce extensions you need for the task at hand.\n[Apply a Group](command:sfdxManager.applyGroupQuickPick)",
            "media": { "markdown": "resources/walkthrough/apply-group.md" }
          },
          {
            "id": "sfdxManager.walkthrough.dependencies",
            "title": "Verify dependencies",
            "description": "See which external prerequisites (Salesforce CLI, Java, Node) are healthy.\n[Check Dependencies](command:sfdxManager.runDependencyCheck)",
            "media": { "markdown": "resources/walkthrough/dependencies.md" }
          },
          {
            "id": "sfdxManager.walkthrough.vsix",
            "title": "Use a local VSIX directory",
            "description": "Point at a folder of .vsix files to test unreleased builds without leaving the marketplace install for production.\n[Open VSIX Setting](command:workbench.action.openSettings?%22salesforcedx-vscode-manager.vsixDirectory%22)",
            "media": { "markdown": "resources/walkthrough/vsix.md" }
          },
          {
            "id": "sfdxManager.walkthrough.statusBar",
            "title": "Status bar indicators",
            "description": "The status bar shows the active group and any VSIX overrides; click either to manage.",
            "media": { "markdown": "resources/walkthrough/status-bar.md" }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc --noEmit && node ./esbuild.js",
    "watch": "tsc --noEmit --watch",
    "clean": "rimraf out dist coverage",
    "bundle:extension": "node ./esbuild.js --production",
    "bundle:vsix": "npm run bundle:extension && npx -y @vscode/vsce package --allow-missing-repository --baseContentUrl https://example.invalid/",
    "vscode:prepublish": "npm run bundle:extension",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^29.5.1",
    "@types/node": "^22",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
